# Server
SERVER_PORT=8080
SERVER_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=jobber
DB_PASSWORD=jobber
DB_NAME=jobber
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# CORS (comma-separated origins, "*" for development only)
ALLOWED_ORIGINS=*

# Frontend URL (enables React-based PDF rendering; falls back to Go templates if empty)
FRONTEND_URL=

# S3 Storage (Hetzner Object Storage)
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_BUCKET=jobber-resumes
S3_REGION=eu-central
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here

# Anthropic AI (optional — enables job import parsing and match score)
ANTHROPIC_API_KEY=

# Google Calendar (optional — all 5 must be set to enable)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URL=
GOOGLE_CALENDAR_FRONTEND_URL=
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=

# Sentry (optional — empty DSN disables error tracking)
SENTRY_DSN=
SENTRY_RELEASE=

# Resend (optional — empty API key uses no-op email sender)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=Jobber <noreply@jobber-app.com>

# Telegram (optional — enables support ticket forwarding)
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=

# Feature flags (all default to true; set to false to disable)
FEATURE_SENTRY_ENABLED=true
FEATURE_EMAIL_ENABLED=true
FEATURE_PAYMENTS_ENABLED=false
